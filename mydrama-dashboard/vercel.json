{
  "version": 2,
  "builds": [
    { "src": "mydrama-dashboard/api/*.js", "use": "@vercel/node" },
    { "src": "mydrama-dashboard/public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/mydrama-dashboard/api/$1" },
    { "src": "/(.*)", "dest": "/mydrama-dashboard/public/$1" }
  ]
}
